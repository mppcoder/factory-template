# Codex-managed Google Drive connector sync for factory-template Sources.
# This repo no longer stores or expects raw Google API credentials for the sync contour.
# The active Google Drive connection is an external Codex/ChatGPT boundary.

GOOGLE_DRIVE_FOLDER_URL=https://drive.google.com/drive/folders/1kagCZTcHD0IA9TviJBCDj7K1NvKa2rfZ?usp=drive_link
GOOGLE_DRIVE_DELETE_STALE=0
GOOGLE_DRIVE_DRY_RUN=1
GOOGLE_DRIVE_SUPPORTS_ALL_DRIVES=0

# Optional repo-local overrides.
FACTORY_TEMPLATE_GDRIVE_EXPORT_NAME=core-hot-15
FACTORY_TEMPLATE_SYNC_REPORT_DIR=_sources-export/factory-template/_sync-reports
