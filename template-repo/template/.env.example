# Optional env overrides for the Google Drive contour of a generated battle project.
# The canonical project-level config now lives in `.chatgpt/google-drive-sources.yaml`.
# Use this file only when you want env-based overrides on top of that YAML layer.

GOOGLE_DRIVE_FOLDER_URL=https://drive.google.com/drive/folders/<replace-with-project-folder-id>
GOOGLE_DRIVE_DELETE_STALE=0
GOOGLE_DRIVE_DRY_RUN=1
GOOGLE_DRIVE_SUPPORTS_ALL_DRIVES=0
