# Только пример. Не коммитьте реальные runtime values.
# Реальный production env должен жить вне repo, обычно в PROJECT_ENV_FILE.

PROJECT_IMAGE=registry.example.com/PROJECT_SLUG:release-tag
PROJECT_CONTAINER_PORT=80
PROJECT_HEALTH_PATH=PROJECT_HEALTH_PATH
PROJECT_PUBLIC_BASE_URL=https://PROJECT_DOMAIN

# Application-specific placeholders только для примера.
APP_ENV=production
APP_SECRET=change-me-store-real-value-in-PROJECT_ENV_FILE
DATABASE_URL=postgres://example_user:change-me@127.0.0.1:5432/example_db
