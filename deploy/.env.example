OPERATOR_PRESET=starter

APP_IMAGE=nginx:1.27-alpine
APP_CONTAINER_NAME=factory-template-app
APP_BIND_ADDRESS=0.0.0.0
APP_PORT=8080
APP_DATA_VOLUME=factory-template-app-data
APP_HEALTHCHECK_ENDPOINT=/
APP_HEALTHCHECK_INTERVAL=30s
APP_HEALTHCHECK_TIMEOUT=5s
APP_HEALTHCHECK_RETRIES=3
APP_HEALTHCHECK_START_PERIOD=20s

# Optional app-db preset. Use OPERATOR_PRESET=app-db or production.
DB_IMAGE=postgres:16-alpine
DB_CONTAINER_NAME=factory-template-db
DB_NAME=app
DB_USER=app
DB_PASSWORD=change-me-generate-a-long-random-secret
DB_PORT=5432
DB_DATA_VOLUME=factory-template-db-data

# Optional backup preset. Use OPERATOR_PRESET=app-db,backup or production.
BACKUP_ENABLED=false
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=7

# Optional reverse-proxy/TLS preset. Use OPERATOR_PRESET=reverse-proxy-tls or production.
REVERSE_PROXY_IMAGE=caddy:2.8-alpine
REVERSE_PROXY_CONTAINER_NAME=factory-template-proxy
DOMAIN=example.com
TLS_EMAIL=ops@example.com
ACME_AGREE=false
HTTP_PORT=80
HTTPS_PORT=443
CADDY_DATA_VOLUME=factory-template-caddy-data
CADDY_CONFIG_VOLUME=factory-template-caddy-config

# Optional healthcheck preset. Значение должно быть HTTP path внутри app container.
HEALTHCHECK_ENDPOINT=/
